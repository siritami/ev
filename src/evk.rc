/**
 * evk.rc - EVKey Resource File
 *
 * Icons, dialogs, and version info for the EVKey application.
 */

#include <windows.h>
#include <commctrl.h>

/* ========================================================================
 * Icons
 * ======================================================================== */

/* Icon resource - using system icon as placeholder */
/* Replace with actual EVKey .ico file for production */
#define IDI_EVK_MAIN 1

/* ========================================================================
 * Dialog Definitions
 * ======================================================================== */

/* Settings Dialog */
#define IDD_CONFIG 1001
#define IDC_METHOD      1010
#define IDC_CHARSET     1011
#define IDC_VIET_ON     1012
#define IDC_AUTO_SWITCH 1013
#define IDC_ALWAYS_VIET 1014
#define IDC_BACKSPACE   1015
#define IDC_START_MIN   1016
#define IDC_AUTO_START  1017
#define IDC_BLACKLIST   1020
#define IDC_ADD_BLACK   1021
#define IDC_REM_BLACK   1022
#define IDC_APPLY       1030
#define IDC_CLOSE       1031

IDD_CONFIG DIALOGEX 0, 0, 320, 280
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "EVKey Settings"
FONT 8, "MS Shell Dlg", 400, 0, 1
BEGIN
    GROUPBOX        "Input Method", -1, 10, 10, 300, 60
    LTEXT           "Method:", -1, 20, 28, 40, 12
    COMBOBOX        IDC_METHOD, 65, 25, 120, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    CHECKBOX        "Vietnamese enabled", IDC_VIET_ON, 200, 28, 100, 12

    GROUPBOX        "Output", -1, 10, 75, 300, 35
    LTEXT           "Charset:", -1, 20, 90, 40, 12
    COMBOBOX        IDC_CHARSET, 65, 87, 120, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    GROUPBOX        "Options", -1, 10, 115, 300, 60
    CHECKBOX        "Auto-switch per application", IDC_AUTO_SWITCH, 20, 130, 130, 12
    CHECKBOX        "Always Vietnamese", IDC_ALWAYS_VIET, 160, 130, 120, 12
    CHECKBOX        "Backspace removes compose char", IDC_BACKSPACE, 20, 145, 150, 12
    CHECKBOX        "Start minimized", IDC_START_MIN, 180, 145, 100, 12
    CHECKBOX        "Auto-start with Windows", IDC_AUTO_START, 20, 160, 130, 12

    GROUPBOX        "Blacklist (apps where EVKey is disabled)", -1, 10, 180, 300, 80
    LISTBOX         IDC_BLACKLIST, 20, 195, 200, 55, LBS_NOTIFY | WS_VSCROLL | WS_BORDER
    PUSHBUTTON      "Add...", IDC_ADD_BLACK, 225, 195, 40, 14
    PUSHBUTTON      "Remove", IDC_REM_BLACK, 225, 215, 40, 14

    PUSHBUTTON      "Apply", IDC_APPLY, 180, 260, 60, 14
    PUSHBUTTON      "Close", IDC_CLOSE, 245, 260, 60, 14
END

/* Converter Dialog */
#define IDD_CONVERTER   2001
#define IDC_CONV_INPUT  2010
#define IDC_CONV_OUTPUT 2011
#define IDC_CONV_METHOD 2012
#define IDC_CONV_CONVERT 2013

IDD_CONVERTER DIALOGEX 0, 0, 400, 250
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "EVKey Text Converter"
FONT 8, "MS Shell Dlg", 400, 0, 1
BEGIN
    LTEXT           "Input (Vietnamese):", -1, 10, 10, 80, 12
    EDITTEXT        IDC_CONV_INPUT, 10, 25, 380, 40, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL

    LTEXT           "Output charset:", -1, 10, 72, 60, 12
    COMBOBOX        IDC_CONV_METHOD, 75, 70, 120, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Convert", IDC_CONV_CONVERT, 200, 70, 60, 14

    LTEXT           "Output:", -1, 10, 92, 30, 12
    EDITTEXT        IDC_CONV_OUTPUT, 10, 105, 380, 100, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL

    PUSHBUTTON      "Close", IDCANCEL, 330, 230, 60, 14
END

/* ========================================================================
 * Version Info
 * ======================================================================== */

#define VI_FILE_DESCRIPTION    "EVKey - Vietnamese Keyboard Input Method"
#define VI_PRODUCT_NAME        "EVKey"
#define VI_PRODUCT_VERSION     "6.0.0.0"
#define VI_FILE_VERSION        "6.0.0.0"
#define VI_INTERNAL_NAME       "EVKey64"
#define VI_ORIGINAL_FILENAME   "EVKey64.exe"
#define VI_COPYRIGHT           "Copyright (C) NCHC Vietnam / Open Source"

#ifdef _DEBUG
    #define VI_PRODUCT_VERSION_STR VI_PRODUCT_VERSION " (Debug)"
#else
    #define VI_PRODUCT_VERSION_STR VI_PRODUCT_VERSION
#endif

VS_VERSION_INFO VERSIONINFO
FILEVERSION     6,0,0,0
PRODUCTVERSION  6,0,0,0
FILEFLAGSMASK   0x3fL
FILEFLAGS       0x0L
FILEOS          0x40004L
FILETYPE        0x1L
FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "NCHC Vietnam"
            VALUE "FileDescription",  VI_FILE_DESCRIPTION
            VALUE "FileVersion",      VI_FILE_VERSION
            VALUE "InternalName",     VI_INTERNAL_NAME
            VALUE "OriginalFilename", VI_ORIGINAL_FILENAME
            VALUE "ProductName",      VI_PRODUCT_NAME
            VALUE "ProductVersion",   VI_PRODUCT_VERSION_STR
            VALUE "LegalCopyright",   VI_COPYRIGHT
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
